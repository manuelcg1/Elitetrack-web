      <and>
        <columnExists tableName="alerts" columnName="speedLimit" />
        <not>
          <columnExists tableName="alerts" columnName="speedlimit" />
        </not>
      </and>
    </preConditions>
    <renameColumn tableName="alerts" oldColumnName="speedLimit" newColumnName="speedlimit" columnDataType="DOUBLE" />
  </changeSet>

