  <changeSet author="elitetrack" id="alerts-create-alert-logs">
    <createTable tableName="alert_logs">
      <column autoIncrement="true" name="id" type="INT">
        <constraints primaryKey="true" />
      </column>
      <column name="alertId" type="INT" />
      <column name="plate" type="VARCHAR(128)" />
      <column name="latitude" type="DOUBLE" />
      <column name="longitude" type="DOUBLE" />
      <column name="driver" type="VARCHAR(128)" />
      <column name="vehicleGroup" type="VARCHAR(128)" />
      <column name="geofenceName" type="VARCHAR(128)" />
      <column name="alertName" type="VARCHAR(128)" />
      <column name="recordedSpeed" type="DOUBLE" />
      <column name="eventTime" type="TIMESTAMP">
        <constraints nullable="false" />
      </column>
    </createTable>
    <createIndex tableName="alert_logs" indexName="idx_alert_logs_event_time">
      <column name="eventTime" />
    </createIndex>
  </changeSet>

  <changeSet author="elitetrack" id="alerts-lowercase-alerts-speedlimit">
