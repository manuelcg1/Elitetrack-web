<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

  <changeSet author="elitetrack" id="alerts-create-geofence-folders-if-missing">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="tc_geofence_folders" />
      </not>
    </preConditions>
    <createTable tableName="tc_geofence_folders">
      <column autoIncrement="true" name="id" type="INT">
        <constraints primaryKey="true" />
      </column>
      <column name="name" type="VARCHAR(128)">
        <constraints nullable="false" />
      </column>
      <column name="description" type="VARCHAR(4000)" />
      <column name="parentid" type="INT" defaultValueNumeric="0" />
      <column name="attributes" type="VARCHAR(4000)" />
    </createTable>
  </changeSet>

  <changeSet author="elitetrack" id="alerts-geofence-folders-add-description-if-missing">
    <preConditions onFail="MARK_RAN">
      <and>
        <tableExists tableName="tc_geofence_folders" />
        <not>
          <columnExists tableName="tc_geofence_folders" columnName="description" />
        </not>
      </and>
    </preConditions>
    <addColumn tableName="tc_geofence_folders">
      <column name="description" type="VARCHAR(4000)" />
    </addColumn>
  </changeSet>

  <changeSet author="elitetrack" id="alerts-geofence-folders-add-parentid-if-missing">
    <preConditions onFail="MARK_RAN">
      <and>
        <tableExists tableName="tc_geofence_folders" />
        <not>
          <columnExists tableName="tc_geofence_folders" columnName="parentid" />
        </not>
      </and>
    </preConditions>
    <addColumn tableName="tc_geofence_folders">
      <column name="parentid" type="INT" defaultValueNumeric="0" />
    </addColumn>
  </changeSet>

  <changeSet author="elitetrack" id="alerts-geofence-folders-add-attributes-if-missing">
    <preConditions onFail="MARK_RAN">
      <and>
        <tableExists tableName="tc_geofence_folders" />
        <not>
          <columnExists tableName="tc_geofence_folders" columnName="attributes" />
        </not>
      </and>
    </preConditions>
    <addColumn tableName="tc_geofence_folders">
      <column name="attributes" type="VARCHAR(4000)" />
    </addColumn>
  </changeSet>

  <changeSet author="elitetrack" id="alerts-create-alerts">
    <createTable tableName="alerts">
      <column autoIncrement="true" name="id" type="INT">
        <constraints primaryKey="true" />
      </column>
      <column name="type" type="VARCHAR(32)" defaultValue="Velocidad">
        <constraints nullable="false" />
      </column>
      <column name="name" type="VARCHAR(128)">
        <constraints nullable="false" />
      </column>
      <column name="speedLimit" type="DOUBLE">
        <constraints nullable="false" />
      </column>
      <column name="active" type="BOOLEAN" defaultValueBoolean="true">
        <constraints nullable="false" />
      </column>
    </createTable>
  </changeSet>

  <changeSet author="elitetrack" id="alerts-create-alert-devices">
    <createTable tableName="alert_devices">
      <column autoIncrement="true" name="id" type="INT">
        <constraints primaryKey="true" />
      </column>
      <column name="alertId" type="INT">
        <constraints nullable="false" />
      </column>
      <column name="deviceId" type="INT">
        <constraints nullable="false" />
      </column>
    </createTable>
    <addForeignKeyConstraint baseTableName="alert_devices" baseColumnNames="alertId"
        constraintName="fk_alert_devices_alert" onDelete="CASCADE"
        referencedTableName="alerts" referencedColumnNames="id" />
    <addForeignKeyConstraint baseTableName="alert_devices" baseColumnNames="deviceId"
        constraintName="fk_alert_devices_device" onDelete="CASCADE"
        referencedTableName="tc_devices" referencedColumnNames="id" />
    <createIndex tableName="alert_devices" indexName="idx_alert_devices_alert">
      <column name="alertId" />
    </createIndex>
  </changeSet>

